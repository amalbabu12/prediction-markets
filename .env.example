# Anthropic API key (required for Claude Code container)
ANTHROPIC_API_KEY=

# Kalshi credentials (optional — public endpoints work without auth)
# Get from: https://kalshi.com/account/api
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Database path (SQLite)
DB_PATH=./data/markets.db

# Collection settings
KALSHI_RATE_LIMIT=10
POLYMARKET_RATE_LIMIT=30
